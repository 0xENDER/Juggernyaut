{
    "scripts": {
        "build-cmake-win-32": "cd .build && cmake .. -DCMAKE_BUILD_TYPE=Release -DJUG_TOOLCHAIN_CONFIGS=.cmake/target-configs/windows-x86_32-on-x86_64.cmake",
        "build-cmake-win-64": "cd .build && cmake .. -DCMAKE_BUILD_TYPE=Release -DJUG_TOOLCHAIN_CONFIGS=.cmake/target-configs/windows-x86_64-on-x86_64.cmake",
        "build-cmake-lix-32": "cd .build && cmake .. -DCMAKE_C_COMPILER=gcc-13 -DCMAKE_CXX_COMPILER=g++-13 -DCMAKE_BUILD_TYPE=Release -DJUG_TOOLCHAIN_CONFIGS=.cmake/target-configs/linux-x86_32-on-x86_64.cmake",
        "build-cmake-lix-64": "cd .build && cmake .. -DCMAKE_C_COMPILER=gcc-13 -DCMAKE_CXX_COMPILER=g++-13 -DCMAKE_BUILD_TYPE=Release -DJUG_TOOLCHAIN_CONFIGS=.cmake/target-configs/linux-x86_64-on-x86_64.cmake",
        "build-binary": "cd .build && cmake --build . --config Release --parallel 4 --verbose",
        "debug-build-cmake": "cd .build && cmake .. -DCMAKE_C_COMPILER=gcc-13 -DCMAKE_CXX_COMPILER=g++-13 -DCMAKE_BUILD_TYPE=Debug -DJUG_TOOLCHAIN_CONFIGS=.cmake/target-configs/linux-x86_64-on-x86_64.cmake",
        "debug-t-build-cmake": "cd .build && cmake .. -DCMAKE_C_COMPILER=gcc-13 -DCMAKE_CXX_COMPILER=g++-13 -DCMAKE_BUILD_TYPE=Debug -DJUG_BUILD_TESTS=ON -DJUG_TOOLCHAIN_CONFIGS=.cmake/target-configs/linux-x86_64-on-x86_64.cmake",
        "debug-build-binary": "cd .build && cmake --build . --config Debug --parallel 4 --verbose",
        "win-clean": "rd /s /q \".build\" && rd /s /q \".out\" && rd /s /q \".dist\"",
        "lix-clean": "rm -f -r \".build\" && rm -f -r \".out\" && rm -f -r \".dist\"",
        "install": "cd .build && cmake --install . --config Release",
        "debug-install": "cd .build && cmake --install . --config Debug",
        "package": "cd .dist && cpack --config ../.build/CPackConfig.cmake -C Release",
        "debug-package": "cd .dist && cpack --config ../.build/CPackConfig.cmake -C Debug",
        "debug": "mkdir .build && npm run debug-build-cmake && npm run debug-build-binary",
        "debug-t": "mkdir .build && npm run debug-t-build-cmake && npm run debug-build-binary",
        "test-d": "cd .build && ctest -C Debug -V -j 3",
        "win64": "mkdir .build && npm run build-cmake-win-64 && npm run build-binary",
        "lix64": "mkdir .build && npm run build-cmake-lix-64 && npm run build-binary",
        "lix32": "mkdir .build && npm run build-cmake-lix-32 && npm run build-binary"
    } 
}