@echo off
echo Cleaning up extra components...

:: dirs
rmdir /s /q "@NATIVE_OUT_DIR@\share"
rmdir /s /q "@NATIVE_OUT_DIR@\include"

:: /bin/+
rmdir /s /q "@NATIVE_OUT_DIR@\bin\cmake"
rmdir /s /q "@NATIVE_OUT_DIR@\bin\pkgconfig"

:: Static libs
del /S /Q "@NATIVE_OUT_DIR@\*.lib"

echo Cleanup complete!
