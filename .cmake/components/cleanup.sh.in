#!/bin/bash
echo "Cleaning up extra components..."

# dirs
rm -rf "@NATIVE_OUT_DIR@/share"
rm -rf "@NATIVE_OUT_DIR@/include"

# /bin/+
rm -rf "@NATIVE_OUT_DIR@/bin/cmake"
rm -rf "@NATIVE_OUT_DIR@/bin/pkgconfig"

# Static libs
find "@NATIVE_OUT_DIR@" -name "*.lib" -type f -delete

echo "Cleanup complete!"
